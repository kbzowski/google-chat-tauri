{
  "$schema": "https://biomejs.dev/schemas/2.5.1/schema.json",
  "files": {
    "includes": [
      "**/*.js",
      "**/*.ts",
      "**/*.svelte",
      "**/*.json",
      "!node_modules",
      "!dist",
      "!src-tauri/target",
      "!src-tauri/gen",
      "!src-tauri/Cargo.lock",
      "!src-tauri/injection.js",
      "!src-tauri/tauri.conf.json"
    ]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100
  },
  "linter": {
    "enabled": true,
    "rules": { "preset": "recommended" }
  },
  "javascript": {
    "formatter": { "quoteStyle": "single", "semicolons": "always" }
  },
  "overrides": [
    {
      "includes": ["**/*.svelte"],
      "linter": {
        "rules": {
          "correctness": {
            "noUnusedImports": "off",
            "noUnusedVariables": "off"
          }
        }
      }
    }
  ]
}
