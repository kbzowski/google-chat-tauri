{
  "$schema": "https://biomejs.dev/schemas/2.4.15/schema.json",
  "files": {
    "includes": [
      "**/*.js",
      "**/*.ts",
      "**/*.svelte",
      "**/*.json",
      "!node_modules",
      "!dist",
      "!src-tauri/target",
      "!src-tauri/gen",
      "!src-tauri/Cargo.lock"
    ]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100
  },
  "linter": {
    "enabled": true,
    "rules": { "recommended": true }
  },
  "javascript": {
    "formatter": { "quoteStyle": "single", "semicolons": "always" }
  }
}
