{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "google-chat-tauri",
  "version": "0.0.1",
  "identifier": "com.google-chat-tauri.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "pnpm dev:all",
    "beforeBuildCommand": "pnpm build:all"
  },
  "app": {
    "security": {
      "csp": null,
      "dangerousDisableAssetCspModification": true
    }
  },
  "bundle": {
    "active": false,
    "targets": ["msi", "nsis"],
    "icon": ["icons/icon.ico"],
    "windows": {
      "webviewInstallMode": { "type": "downloadBootstrapper" },
      "wix": {
        "language": ["en-US", "pl-PL"]
      },
      "nsis": {
        "installMode": "currentUser",
        "languages": ["English", "Polish"]
      }
    }
  }
}
