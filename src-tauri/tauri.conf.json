{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "google-chat-tauri",
  "version": "0.1.0",
  "identifier": "com.google-chat-tauri.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "pnpm dev:all",
    "beforeBuildCommand": "pnpm build:all"
  },
  "app": {
    "security": {
      "csp": null,
      "dangerousDisableAssetCspModification": true
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDU4NTBFOTNBRDU5ODA4RUYKUldUdkNKalZPdWxRV0d0emNtaFgzc1U3dC9LYTlvL0ZzOUJPWDNBN0U5OVlRTlZiU2RwK25Eb3AK",
      "endpoints": [
        "https://github.com/kbzowski/google-chat-tauri/releases/latest/download/latest.json"
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi", "nsis"],
    "publisher": "Krzysztof Bzowski",
    "shortDescription": "Tauri reimplementation of Google Chat desktop client for Windows",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "webviewInstallMode": {
        "type": "downloadBootstrapper"
      },
      "wix": {
        "language": ["en-US"]
      },
      "nsis": {
        "installMode": "currentUser",
        "languages": ["English"]
      }
    }
  }
}
