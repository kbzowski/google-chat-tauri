{
  "$schema": "https://schemas.tauri.app/schema/2/capabilities/capability.json",
  "identifier": "remote-access",
  "description": "Permissions for the main window loading Google's remote URLs (chat, mail, accounts). Allows the Tauri IPC bridge plus shell:open so window.open(_blank) from Google Chat hands the URL to the system default browser.",
  "remote": {
    "urls": [
      "https://mail.google.com/*",
      "https://chat.google.com/*",
      "https://accounts.google.com/*",
      "https://*.google.com/*"
    ]
  },
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:event:default",
    "core:event:allow-emit",
    "core:event:allow-listen",
    {
      "identifier": "shell:allow-open",
      "allow": [{ "url": "https://**" }]
    },
    "allow-injection-ipc"
  ]
}
