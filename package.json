{
  "name": "google-chat-tauri",
  "version": "0.0.1",
  "private": true,
  "license": "MIT",
  "description": "Tauri reimplementation of Google Chat desktop client for Windows",
  "type": "module",
  "scripts": {
    "tauri": "tauri",
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "build:injection": "vite build --config vite.config.injection.ts",
    "dev:injection": "vite build --watch --mode development --config vite.config.injection.ts",
    "dev:all": "concurrently -n ui,inj -c blue,magenta \"pnpm dev\" \"pnpm dev:injection\"",
    "build:all": "pnpm build && pnpm build:injection",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "typecheck": "tsc --noEmit && svelte-check --tsconfig ./tsconfig.json"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "@tauri-apps/api": "^2.11.0",
    "@tauri-apps/cli": "^2.11.1",
    "concurrently": "^9.2.1",
    "lefthook": "^2.1.6",
    "svelte": "^5.55.5",
    "svelte-check": "^4.4.8",
    "typescript": "^6.0.3",
    "vite": "^8.0.12"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "lefthook"
    ]
  }
}
